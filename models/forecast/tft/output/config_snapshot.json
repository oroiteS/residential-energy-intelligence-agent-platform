{
  "data": {
    "metadata_path": "/root/models/data/processed/forecast/forecast_samples.csv",
    "feature_spec_path": "/root/models/data/processed/forecast/forecast_feature_spec.json",
    "features_path": null,
    "targets_path": null,
    "split_mode": "by_house",
    "train_ratio": 0.7,
    "val_ratio": 0.15,
    "batch_size": 256,
    "num_workers": 12,
    "pin_memory": true,
    "prefetch_factor": 4,
    "baseline_week_weight": 0.8,
    "baseline_recent_weight": 0.2,
    "aggregate_feature_name": "aggregate",
    "normalization_quantile": 0.95
  },
  "model": {
    "hidden_size": 96,
    "lstm_layers": 2,
    "attention_heads": 4,
    "dropout": 0.15,
    "return_attention_weights": false,
    "router_prior_weight": 1.0,
    "global_gate_bias_init": -0.2,
    "local_gate_bias_init": 0.0
  },
  "loss": {
    "huber_delta": 1.0,
    "diff_weight": 0.2,
    "peak_weight": 0.4,
    "peak_quantile": 0.9,
    "ramp_weight": 0.3,
    "guard_weight": 0.05,
    "guard_margin": 0.02,
    "gate_regularization": 0.001,
    "regularization_warmup_epochs": 4,
    "regularization_ramp_epochs": 6
  },
  "train": {
    "output_dir": "/root/models/forecast/tft/output",
    "seed": 42,
    "max_epochs": 50,
    "learning_rate": 0.001,
    "weight_decay": 0.0001,
    "gradient_clip_val": 1.0,
    "accelerator": "auto",
    "devices": 1,
    "precision": "bf16-mixed",
    "early_stopping_patience": 8,
    "log_every_n_steps": 10,
    "deterministic": false,
    "benchmark": true,
    "enable_tf32": true,
    "matmul_precision": "high",
    "compile_model": false,
    "compile_mode": "max-autotune",
    "enable_progress_bar": true,
    "progress_bar_refresh_rate": 10,
    "enable_model_summary": false,
    "num_sanity_val_steps": 0
  },
  "test": {
    "checkpoint_path": null,
    "output_dir": "/root/models/forecast/tft/output/test"
  }
}