# Flask 调试模式。开发环境可设为 true，生产环境建议设为 false。
FLASK_DEBUG=true

# Flask 监听地址。0.0.0.0 表示允许局域网或容器外部访问。
APP_HOST=0.0.0.0

# Flask 监听端口。前端代理或 Nginx 需要转发到该端口。
APP_PORT=5000

# 后端 API 前缀。前端当前默认请求 /api/v1。
API_PREFIX=/api/v1

# MySQL 主机地址。
DB_HOST=127.0.0.1

# MySQL 端口。
DB_PORT=3306

# MySQL 用户名。
DB_USER=root

# MySQL 密码。本地真实密码写入 .env，不要提交到仓库。
DB_PASSWORD=

# MySQL 数据库名，对应根目录 schema.sql 中的 resident。
DB_NAME=resident

# 后端运行时文件根目录，用于保存上传文件、预处理结果、报告等。
STORAGE_ROOT=./storage

# 单次上传文件大小上限，单位 MB。
MAX_CONTENT_LENGTH_MB=20

# 峰时段配置，多个时间段用英文逗号分隔；未落入峰时段的数据按谷时处理。
PEAK_PERIODS=07:00-11:00,18:00-23:00

# 谷时段配置。本项目只有峰、谷两类，没有平时段，所以这里显式覆盖峰时以外的全部时间。
VALLEY_PERIODS=23:00-07:00,11:00-18:00

# 接受的最细上传粒度，单位分钟。通常保持 1 即可。
ACCEPTED_MIN_GRANULARITY_MINUTES=1

# 接受的最粗上传粒度，单位分钟。60 表示用户上传数据至少要达到小时级。
ACCEPTED_MAX_GRANULARITY_MINUTES=60

# 预测模型使用过去 30 天预测未来 7 天，因此上传数据按日聚合后必须至少覆盖 30 天。
FORECAST_HISTORY_DAYS=30

# OpenAI 兼容接口地址，填写到接口根路径即可，不要带 /chat/completions。
LLM_BASE_URL=https://api.openai.com/v1

# OpenAI 或兼容服务的 API Key。
LLM_API_KEY=

# Agent 使用的模型名，例如 gpt-4.1、gpt-4o-mini 或兼容服务提供的模型名。
LLM_MODEL=

# Agent 生成温度。数值越低越稳定，越高越发散。
LLM_TEMPERATURE=0.2

# Agent 单次请求超时时间，单位秒。
LLM_TIMEOUT_SECONDS=120

# 报告生成专用的模型调用超时时间，单位秒。默认可与普通问答保持一致。
LLM_REPORT_TIMEOUT_SECONDS=360

# PDF 渲染超时时间，单位秒。md2pdf 会在子进程中生成版式更好的 PDF。
PDF_RENDER_TIMEOUT_SECONDS=120

# PDF 主题名称。可选值取决于内置 md2pdf 支持的主题。
PDF_THEME=github-light

# 是否生成封面页。true 表示开启，false 表示关闭。
PDF_COVER=true

# 是否生成目录页。true 表示开启，false 表示关闭。
PDF_TOC=true

# 内置 md2pdf 脚本路径。一般无需修改，除非你要替换渲染器。
MD2PDF_SCRIPT_PATH=app/tools/md2pdf.py
