# 应用基础配置
APP_NAME=resident-energy-backend
APP_HOST=127.0.0.1
APP_PORT=8080
GIN_MODE=debug

# 数据库连接
MYSQL_DSN=root:root@tcp(127.0.0.1:3306)/resident?charset=utf8mb4&parseTime=True&loc=Local

# Python 模型/智能体服务
# 默认由同一个 models_agent 服务同时承载模型与智能问答
PYTHON_SERVICE_BASE_URL=http://127.0.0.1:8001
USE_STUB_CLIENTS=false

# 请求超时
REQUEST_TIMEOUT_SECONDS=15

# 本地目录
DATA_UPLOAD_DIR=./uploads/datasets
OUTPUT_ROOT_DIR=./outputs

# Markdown -> PDF 导出样式
REPORT_PDF_THEME=github-light
REPORT_PDF_COVER=false
REPORT_PDF_TOC=false
